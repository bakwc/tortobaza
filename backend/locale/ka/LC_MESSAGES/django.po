msgid "Cart is empty."
msgstr "კალათა ცარიელია."

msgid "Invalid schedule tier."
msgstr "არასწორი მიწოდების დონე."

msgid "Express delivery is not available for this order."
msgstr "ეს შეკვეთისთვის ექსპრეს მიწოდება შეუძლებელია."

msgid "Invalid schedule mode."
msgstr "არასწორი განრიგის რეჟიმი."

msgid "Date and time window are required for scheduled delivery."
msgstr "გეგმით მიწოდებას სჭირდება თარიღი და დროის შუალედი."

msgid "Selected time slot is not available."
msgstr "არჩეული დრო ხელმიუწვდომელია."

msgid "This field is required for a scheduled slot."
msgstr "ეს ველი სავალდებულოა დაგეგმილი სლოტის არჩევისას."

msgid "Must be empty when using express scheduling."
msgstr "ექსპრესის დროს ეს ველი ცარიელი უნდა იყოს."

msgid "Promo code is not active."
msgstr "პრომო კოდი არ არის აქტიური."

msgid "Promo code is not yet valid."
msgstr "პრომო კოდი ჯერ არ იწყება."

msgid "Promo code has expired."
msgstr "პრომო კოდის ვადა გავიდა."

msgid "Promo code usage limit reached."
msgstr "პრომოს გამოყენების ლიმიტი ამოიწურა."

